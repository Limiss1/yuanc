# Exchange API配置 (对应 ExchangeConfig 的 env_prefix="EXCHANGE_")
EXCHANGE_NAME=binance
EXCHANGE_API_KEY=your_api_key_here
EXCHANGE_API_SECRET=your_secret_key_here
EXCHANGE_TESTNET=true

# Strategy配置 (对应 StrategyConfig 的 env_prefix="STRATEGY_")
STRATEGY_NAME=ai
STRATEGY_CONFIDENCE_THRESHOLD=0.65

# Risk配置 (对应 RiskConfig 的 env_prefix="RISK_")
RISK_MAX_DRAWDOWN=0.15
RISK_DAILY_LOSS_LIMIT=0.05

# Data配置 (对应 DataConfig 的 env_prefix="DATA_")
DATA_HISTORICAL_DAYS=30

